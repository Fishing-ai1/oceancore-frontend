{
  "name": "oceancore-ai-mobile-wrapper",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare:web": "node scripts/prepare-web.mjs",
    "cap:sync": "npm run prepare:web && cap sync",
    "cap:add:android": "cap add android",
    "cap:add:ios": "cap add ios",
    "android:debug": "npm run cap:sync && cd android && gradlew.bat assembleDebug",
    "android:release": "npm run cap:sync && cd android && gradlew.bat assembleRelease",
    "open:android": "cap open android",
    "open:ios": "cap open ios"
  },
  "dependencies": {
    "@capacitor/android": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@capacitor/ios": "^7.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.0.0",
    "typescript": "^6.0.3"
  }
}
