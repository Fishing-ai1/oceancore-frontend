      "destination": "https://fishing-ai-backend.onrender.com/api/:path*"
    },
    {
      "source": "/ai/:path*",
      "destination": "https://fishing-ai-backend.onrender.com/ai/:path*"
    },
    {
      "source": "/community/:path*",
      "destination": "https://fishing-ai-backend.onrender.com/community/:path*"
    },
    {
      "source": "/rewards/:path*",
