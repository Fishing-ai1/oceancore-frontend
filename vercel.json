{
  "rewrites": [
    {
      "source": "/sw.js",
      "destination": "/fishing-ai-frontend/sw.js"
    },
    {
      "source": "/manifest.webmanifest",
      "destination": "/fishing-ai-frontend/manifest.webmanifest"
    },
    {
      "source": "/offline.html",
      "destination": "/fishing-ai-frontend/offline.html"
    },
    {
      "source": "/assets/:path*",
      "destination": "/fishing-ai-frontend/assets/:path*"
    },
    {
      "source": "/health",
      "destination": "https://fishing-ai-backend.onrender.com/health"
    },
    {
      "source": "/auth/:path*",
      "destination": "https://fishing-ai-backend.onrender.com/auth/:path*"
    },
    {
      "source": "/admin/:path*",
      "destination": "https://fishing-ai-backend.onrender.com/admin/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "https://fishing-ai-backend.onrender.com/api/:path*"
    },
    {
      "source": "/ai/:path*",
      "destination": "https://fishing-ai-backend.onrender.com/ai/:path*"
    },
    {
      "source": "/community/:path*",
      "destination": "https://fishing-ai-backend.onrender.com/community/:path*"
    },
    {
      "source": "/billing/:path*",
      "destination": "https://fishing-ai-backend.onrender.com/billing/:path*"
    },
    {
      "source": "/legal/:path*",
      "destination": "https://fishing-ai-backend.onrender.com/legal/:path*"
    },
    {
      "source": "/species-detect",
      "destination": "https://fishing-ai-backend.onrender.com/species-detect"
    }
  ]
}
